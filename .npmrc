# Supply-chain mitigation: do not install package versions published in the last 24 hours.
# Requires pnpm >= 10.16. See https://pnpm.io/settings#minimumreleaseage
minimum-release-age=1440

# Block transitive deps from git/tarball URLs; only direct deps may use exotic sources.
# Requires pnpm >= 10.26. See https://pnpm.io/settings#blockexoticsubdeps
block-exotic-subdeps=true

# Urgent security patch bypass options:
# 1. Temporarily: minimum-release-age=0
# 2. Per package: minimum-release-age-exclude[]=package-name
# 3. Per version: minimum-release-age-exclude[]=package@1.2.3
